# ── Ember & Scale — backend configuration ────────────────────────────────────
# Copy to `.env` and adjust. The server reads these at startup.
# (Loaded automatically when you run the server via `--env-file=.env`, see README.)

# This is only the server-startup DEFAULT — the chat UI's provider selector
# (top navbar) sends the chosen provider on every request, so normal use never
# falls back to this value. It matters for API clients that skip the selector.
#
# Which LLM backs the chat. One of: claude | copilot | ollama | openai | azure | mock
# - claude  : (default) the LOCAL Claude CLI (`claude`). Requires you to be logged
#             in — run `claude login` once, or export ANTHROPIC_API_KEY. No key goes
#             in this app; the CLI uses whatever auth it already has.
# - copilot : the LOCAL GitHub Copilot CLI (`copilot`, see https://gh.io/copilot-cli).
#             Requires you to already be logged in via the CLI's own auth flow.
# - ollama  : a local Ollama model. Requires `ollama serve` running.
# - openai  : OpenAI or ANY OTHER OpenAI-compatible endpoint (LM Studio, vLLM…)
# - azure   : Azure OpenAI (API key OR locally logged-in identity)
# - mock    : no LLM at all. Streams canned OpenUI-Lang. Offline demo / smoke test.
LLM_PROVIDER=claude

# Claude CLI model alias (opus | sonnet | haiku | fable | …). Default: sonnet
CLAUDE_MODEL=sonnet

# ── copilot ──────────────────────────────────────────────────────────────────
# GitHub Copilot CLI model override, if the CLI supports selecting one — leave
# unset to use the CLI's own default.
COPILOT_MODEL=

# ── ollama ───────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=gemma4:12b

# ── openai / other OpenAI-compatible endpoints ───────────────────────────────
# Cloud OpenAI:
#   LLM_PROVIDER=openai
#   OPENAI_API_KEY=sk-...
#   OPENAI_MODEL=gpt-4o-mini
# Any other OpenAI-compatible server (LM Studio, vLLM, OpenRouter…):
#   LLM_PROVIDER=openai
#   OPENAI_BASE_URL=http://localhost:1234/v1
#   OPENAI_MODEL=...
#   OPENAI_API_KEY=not-needed          # any non-empty string
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# ── azure ────────────────────────────────────────────────────────────────────
# Required:
#   LLM_PROVIDER=azure
#   AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
#   AZURE_OPENAI_DEPLOYMENT=<your-deployment-name>
# Auth — pick ONE:
#   a) API key:            AZURE_OPENAI_API_KEY=<key>
#   b) Locally logged in:  leave AZURE_OPENAI_API_KEY empty and run `az login`
#                          (uses DefaultAzureCredential — supports managed identity too)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_API_KEY=
